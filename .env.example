# ==============================
# Core Database (ETL + dbt)
# ==============================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=topcv_dw
DB_USER=topcv_user
DB_PASSWORD=replace_with_strong_password
DB_SCHEMA=raw

# PostgreSQL container bootstrap
POSTGRES_DB=topcv_dw
POSTGRES_USER=topcv_user
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_EXPOSE_PORT=5432

# Metabase
METABASE_EXPOSE_PORT=3000
METABASE_URL=http://metabase:3000
METABASE_SITE_NAME=TopCV Analytics
METABASE_ADMIN_FIRST_NAME=TopCV
METABASE_ADMIN_LAST_NAME=Admin
METABASE_ADMIN_EMAIL=admin@topcv.local
METABASE_ADMIN_PASSWORD=replace_with_metabase_admin_password
METABASE_DATABASE_DISPLAY_NAME=TopCV Data Warehouse
# Override if needed; defaults fall back to DB_* values
METABASE_TARGET_DB_HOST=postgres
METABASE_TARGET_DB_PORT=5432
METABASE_TARGET_DB_NAME=topcv_dw
METABASE_TARGET_DB_USER=topcv_user
METABASE_TARGET_DB_PASSWORD=replace_with_strong_password

# ==============================
# Airflow Internal Metadata DB
# ==============================
AIRFLOW_DB_HOST=postgres
AIRFLOW_DB_PORT=5432
AIRFLOW_DB_NAME=airflow
# Use the same DB user as POSTGRES_USER unless you explicitly create a separate Airflow DB user.
AIRFLOW_DB_USER=topcv_user
AIRFLOW_DB_PASSWORD=replace_with_strong_password

AIRFLOW_WEBSERVER_SECRET_KEY=replace_with_long_random_secret
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=replace_with_admin_password
AIRFLOW_ADMIN_EMAIL=admin@example.com

# ==============================
# Runtime / Paths
# ==============================
PROJECT_DIR=/opt/project
PYTHON_BIN=python3

# ==============================
# dbt Runtime
# ==============================
DBT_THREADS=2
DBT_PROJECT_DIR=/opt/project/dbt_transform
DBT_PROFILES_DIR=/opt/project/dbt_transform

# ==============================
# Scraper Runtime Controls
# ==============================
SCRAPER_START_PAGE=1
SCRAPER_MAX_PAGES=500
SCRAPER_MAX_WORKERS=2
SCRAPER_PAGE_DELAY_MIN=1.0
SCRAPER_PAGE_DELAY_MAX=2.0
